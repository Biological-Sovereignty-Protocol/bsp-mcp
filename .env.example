# Environment variables for @biological-sovereignty-protocol/mcp

# ─── Identity (required) ──────────────────────────────────────────────

# The user's BSP biological identity domain.
# Required by ConsentGuard; without it every tool call fails fast.
BSP_BEO_DOMAIN=yourname.bsp

# ConsentToken ID issued by the BEO holder authorizing this AI to read data.
# (The holder creates this via their BSP app or the SDK's AccessManager.issueConsent.)
# Warning: This token ID authorizes AI access to biological data — treat as sensitive.
BSP_CONSENT_TOKEN_ID=tok_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─── Signing (required for write tools) ───────────────────────────────

# Ed25519 private key (128-char hex) used to sign write operations
# (bsp_lock_beo, bsp_unlock_beo, bsp_destroy_beo, bsp_revoke_all_tokens).
# Read-only deployments MAY omit this; attempting a write tool will error
# with PRIVATE_KEY_MISSING.
# Warning: Never commit this value. Treat as the most sensitive secret.
BSP_PRIVATE_KEY=

# ─── Network (optional) ───────────────────────────────────────────────

# Registry API endpoint. Defaults to the mainnet public endpoint.
# BSP_REGISTRY_URL=https://api.biologicalsovereigntyprotocol.com

# Logical network label shown in server diagnostics (mainnet | testnet | devnet).
# Purely informational — the actual chain is determined by BSP_REGISTRY_URL.
# BSP_NETWORK=mainnet
