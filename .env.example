# Environment variables for @bsp/mcp server

# The user's BSP biological identity domain
BSP_BEO_DOMAIN=yourname.bsp

# ConsentToken ID issued by the BEO holder authorizing this AI to read data
# (The holder creates this via their BSP app or the SDK's AccessManager.issueConsent)
# ⚠️  This token ID authorizes AI access to biological data — treat as sensitive
BSP_CONSENT_TOKEN_ID=tok_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Network: mainnet | testnet | local
BSP_NETWORK=mainnet

# Registry URL (default: https://registry.biologicalsovereigntyprotocol.com)
# BSP_REGISTRY_URL=https://registry.biologicalsovereigntyprotocol.com

# Arweave node (default: https://arweave.net)
# BSP_ARWEAVE_NODE=https://arweave.net
